# Overrides VITE_API_URL from .env while running `vite` / `npm run dev`.
# Empty value = browser calls same origin; Vite proxies /liveness, /match, /register, /agents to local FastAPI.
#
# Requires the API running (otherwise: ECONNREFUSED 127.0.0.1:8000). From repo root, in another terminal:
#   cd backend && uvicorn main:app --reload --host 127.0.0.1 --port 8000
# If uvicorn uses another port, set e.g. VITE_DEV_PROXY_TARGET=http://127.0.0.1:9000
VITE_API_URL=
