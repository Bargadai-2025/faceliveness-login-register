# Backend: from repo root install with  python -m pip install -r backend/requirements.txt
# Run API:  cd backend && uvicorn main:app --reload --host 127.0.0.1 --port 8000
# Save requirements.txt as UTF-8 if you edit it (Notepad "UTF-8"; avoid UTF-16 or pip errors).

# Local Postgres: create database `faceliveness`.
#
# Option A — set the local `postgres` user password (quoted characters in password are OK; URL-encoded automatically).
POSTGRES_PASSWORD=localhost
#
# Option B — full DSN (Neon / RDS / local). When non-empty, overrides POSTGRES_PASSWORD.
# DATABASE_URL=postgresql://postgres:secret@127.0.0.1:5432/faceliveness
DATABASE_URL=

DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_COMMAND_TIMEOUT=30

# Local/dev only: skip YOLO + background removal on POST /match (much faster). Do not enable in production.
# FAST_MATCH=1

# --- Weighted spoof / replay risk (0–100; higher = more replay-like) ---
# SPOOF_REJECT_THRESHOLD=74
# SPOOF_MATCH_THRESHOLD=78
# SPOOF_STREAMING_SMOOTH_THRESHOLD=71
# SPOOF_TEMPORAL_WINDOW=5
# SPOOF_TEMPORAL_MIN_HIGH_FRAMES=3
# SPOOF_EMA_ALPHA=0.28
# SPOOF_CORR_STRONG_MIN=2
#
# Weights (defaults favor depth/biology/device/challenge over reflection/flicker):
# SPOOF_WEIGHT_DEPTH_PARALLAX=40
# SPOOF_WEIGHT_BIOLOGICAL=40
# SPOOF_WEIGHT_DEVICE_REPLAY=30
# SPOOF_WEIGHT_CHALLENGE=28
# SPOOF_WEIGHT_TEXTURE=20
# SPOOF_WEIGHT_MOIRE=15
# SPOOF_WEIGHT_FLICKER=5
# SPOOF_WEIGHT_REFLECTION=5
# SPOOF_WEIGHT_FLAT_PLANE=12
# SPOOF_WEIGHT_SCREEN_BORDER=15
# SPOOF_WEIGHT_BG_MOTION=18
# SPOOF_WEIGHT_PERSPECTIVE=8
# SPOOF_WEIGHT_RECT_GLARE=10

# Frontend production API (set when building: frontend/.env.production or CI env).
# Same host + nginx /api/ strip (see backend/nginx-faceliveliness.example.conf):
# VITE_API_URL=https://faceliveliness.bargad.ai/api
# VITE_API_URL=https://facematch-test.onrender.com

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
