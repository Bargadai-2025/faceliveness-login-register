# Backend: from repo root install with  python -m pip install -r backend/requirements.txt

# Run API:  cd backend && uvicorn main:app --reload --host 127.0.0.1 --port 8000

# Save requirements.txt as UTF-8 if you edit it (Notepad "UTF-8"; avoid UTF-16 or pip errors).



# Local Postgres: create database `faceliveness`.

#

# Option A — set the local `postgres` user password (quoted characters in password are OK; URL-encoded automatically).

POSTGRES_PASSWORD=localhost

#

# Option B — full DSN (Neon / RDS / local). When non-empty, overrides POSTGRES_PASSWORD.

# DATABASE_URL=postgresql://postgres:secret@127.0.0.1:5432/faceliveness

DATABASE_URL=



DB_POOL_MIN_SIZE=1

DB_POOL_MAX_SIZE=10

DB_COMMAND_TIMEOUT=30



# Local/dev only: skip remove_background on POST /match (YOLO + spoof still run). Do not enable in production.

# FAST_MATCH=1



# Face match (cosine similarity on L2-normalized 512-d FaceNet embeddings)

# FACE_DETECT_MAX_SIDE=800

# MATCH_MIN_CONFIDENCE_BARGAD=0.72

# MATCH_MIN_CONFIDENCE_LFW=0.62

# MATCH_MIN_TOP2_MARGIN=0.05



# Liveness: run depth + light + micro before gestures (recommended for anti-spoof)

LIVENESS_FAST_SETUP=0



# Liveness performance (device detection)

# YOLO_WEIGHTS=yolov8n.pt

# LIVENESS_YOLO_CONF=0.28

# LIVENESS_DEVICE_NEAR_DR=0.12
# Laptop webcam capture: YOLO "laptop" in frame is treated as ambient context, not screen replay.

# LIVENESS_CALIBRATION_FRAMES=3

# LIVENESS_DEPTH_FRAMES=2

# LIVENESS_LIGHT_PRE_FRAMES=2

# LIVENESS_LIGHT_POST_FRAMES=2

# LIVENESS_MICRO_FRAMES=2

# LIVENESS_GESTURE_INSTRUCTION_SEC=0.45
# Quick head turns: lower sustain + peak tracking (defaults below).
# LIVENESS_TURN_SUSTAINED_FRAMES=2
# LIVENESS_TURN_YAW_FRAC=0.032
# LIVENESS_TURN_MIRROR=0
# Set LIVENESS_TURN_MIRROR=1 if turn left/right or look left/right feel reversed.
# LIVENESS_PITCH_FRAC=0.028
# LIVENESS_HOLD_SUSTAINED_FRAMES=2
# LIVENESS_HOLD_DURATION_SEC=0.10

# LIVENESS_GESTURE_COOLDOWN_SEC=0.10

# LIVENESS_SUSTAINED_FRAMES=5

# LIVENESS_HOLD_DURATION_SEC=0.22



# Post-selfie PAD (phone / tablet / laptop / screen) — display-aware lighting

# MATCH_YOLO_CONF=0.22
# MATCH_BEZEL_SIDE_FRAC=0.075
# MATCH_BEZEL_DARK_RATIO=0.72

# MATCH_DEVICE_NEAR_FACE_DR=0.18
# Full-frame screen replay (PNG normalize + 3x3 grid + moiré/blur/banding):
# MATCH_FULLFRAME_HARD_REJECT=0.48
# MATCH_FULLFRAME_SCREEN_REPLAY=0.36
# MATCH_FULLFRAME_MIN_SIGNALS=3

# MATCH_DEVICE_HARD_IOU=0.32

# MATCH_REFLECTION_RAW_MAX=0.48

# MATCH_HARD_REJECT_SPOOF=1

# MATCH_HARD_REJECT_SCREEN_REFLECTION=1

# MATCH_MIN_FACE_BRIGHTNESS=35

# MATCH_MAX_FACE_BRIGHTNESS=252

# MATCH_MIN_FACE_BRIGHTNESS_STD=10

# MATCH_MAX_CLIPPED_HIGHLIGHT_RATIO=0.20

# SPOOF_SINGLE_FRAME_THRESHOLD=42



# --- Weighted spoof / replay risk (0–100; higher = more replay-like) ---

# SPOOF_REJECT_THRESHOLD=76

# SPOOF_MATCH_THRESHOLD=86

# SPOOF_STREAMING_SMOOTH_THRESHOLD=71

# SPOOF_TEMPORAL_WINDOW=5

# SPOOF_TEMPORAL_MIN_HIGH_FRAMES=3

# SPOOF_EMA_ALPHA=0.28

# SPOOF_CORR_STRONG_MIN=2

# SPOOF_TEMPORAL_HITS_REQUIRED=3

#

# Weights (defaults favor depth/biology/device/challenge over reflection/flicker):

# SPOOF_WEIGHT_DEPTH_PARALLAX=40

# SPOOF_WEIGHT_BIOLOGICAL=40

# SPOOF_WEIGHT_DEVICE_REPLAY=30

# SPOOF_WEIGHT_CHALLENGE=28

# SPOOF_WEIGHT_TEXTURE=20

# SPOOF_WEIGHT_MOIRE=15

# SPOOF_WEIGHT_FLICKER=5

# SPOOF_WEIGHT_REFLECTION=5

# SPOOF_WEIGHT_FLAT_PLANE=12

# SPOOF_WEIGHT_SCREEN_BORDER=15

# SPOOF_WEIGHT_BG_MOTION=18

# SPOOF_WEIGHT_PERSPECTIVE=8

# SPOOF_WEIGHT_RECT_GLARE=10

# SPOOF_WEIGHT_HIGH_BRIGHT_SCREEN=22

# SPOOF_WEIGHT_PIXEL_GRID=12

# Multi-factor risk fusion (POST /match) — no single-signal reject
# PoC: slightly stricter reject = fewer false positives for genuine users
# RISK_REJECT_THRESHOLD=76
# RISK_PENALTY_THRESHOLD=48
# RISK_CONFIRM_FACTORS_MIN=3
# RISK_FACTOR_HIGH=58

# PoC stability (optional Redis — falls back to in-memory if unset)
# REDIS_URL=redis://127.0.0.1:6379/0
# SESSION_REDIS_SYNC_EVERY_N_FRAMES=15

# Tier-2 concurrency (single machine ~20–50 users)
# MAX_CONCURRENT_INFERENCE=3
# EMBEDDING_CACHE_ENABLED=1
# DB_POOL_MAX_SIZE=20
# RATE_LIMIT_ENABLED=1
# RATE_LIMIT_FRAME_MAX=120
# RATE_LIMIT_MATCH_MAX=15
# LOG_LEVEL=INFO

# In-memory challenge frame verification (gesture phase → selfie)
# CHALLENGE_SELFIE_MIN_SIM=0.58
# CHALLENGE_CROSS_MIN_SIM=0.62
# CHALLENGE_BG_MIN_SIM=0.50
# CHALLENGE_FACE_RATIO_MIN_FACTOR=0.42
# CHALLENGE_FACE_RATIO_MAX_FACTOR=2.35

# Frontend production API (set when building: frontend/.env.production or CI env).

# Same host + nginx /api/ strip (see backend/nginx-faceliveliness.example.conf):

# VITE_API_URL=https://faceliveliness.bargad.ai/api

# VITE_API_URL=https://facematch-test.onrender.com



CLOUDINARY_CLOUD_NAME=your_cloud_name

CLOUDINARY_API_KEY=your_api_key

CLOUDINARY_API_SECRET=your_api_secret

